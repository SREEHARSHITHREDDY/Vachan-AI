# Copy this file to .env and fill in real values. Never commit .env itself.

# Anthropic API key — required for the Extraction Service to make real calls
ANTHROPIC_API_KEY=

# LLM model to use
LLM_MODEL=claude-sonnet-4-6

# Database (used once the Lifecycle/DB layer module is built)
DATABASE_URL=postgresql://localhost:5432/vachanai

# Extraction tuning
EXTRACTION_MAX_TOKENS=500
EXTRACTION_TEMPERATURE=0.0
